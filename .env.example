# =============================================================================
# Resolve Aí — Environment Variables
#
# Copy this file to .env and fill in your own values.
# Never commit the .env file — it is listed in .gitignore.
#
#   cp .env.example .env
# =============================================================================

# --- LLM Provider ------------------------------------------------------------
# Which LLM to use. Switch between environments without changing code.
# Options: gemini | ollama
LLM_PROVIDER=gemini

# Google API key (get yours at https://aistudio.google.com/)
GOOGLE_API_KEY=

# Gemini model to use
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# --- Ollama (local development — zero cost) ----------------------------------
# Run locally with: ollama pull llama3.2 && ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Vector Store ------------------------------------------------------------
# Options: chroma | vertex
VECTOR_STORE=chroma

# Local ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma_db

# --- Google Cloud (production deployment) ------------------------------------
GOOGLE_PROJECT_ID=
GOOGLE_REGION=us-central1

# --- API Server --------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated allowed origins for CORS
API_CORS_ORIGINS=http://localhost:3000

# --- Logging & Environment ---------------------------------------------------
# Options: development | production
ENVIRONMENT=development
LOG_LEVEL=INFO
